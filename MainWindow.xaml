<Window x:Class="CyberSecurityBotGUI1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityBotGUI1"
        mc:Ignorable="d"
        Title="MEGATRON" Height="450" Width="800" >
    <Grid Background="#0D1">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        
        <!--CHAT AREA-->
            <RichTextBox x:Name="ChatBox"
                         Margin="10"
                         IsReadOnly="True"
                         Background="Blue"
                         Foreground="White"/>
            
            <!--INPUT AREA-->
        <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="10">

            <!--USER INPUT-->
            <TextBox x:Name="InputBox"
                         Width="500"
                         Height="40"
                         FontSize="16"/>

            <!--SEND BUTTON-->
            <Button Content="Send"
                        Width="120"
                        Height="40"
                        Margin="10,0,0,0"
                        Click="SendButton_Click"/>

        </StackPanel>



    </Grid>
</Window>
